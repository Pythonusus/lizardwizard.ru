{
  "name": "lizardwizard.ru",
  "version": "0.1.0",
  "private": true,
  "description": "Static website for listing my pet projects",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pythonusus/lizardwizard.ru.git"
  },
  "author": "Petr Malafeev",
  "license": "MIT",
  "homepage": "https://lizardwizard.ru",
  "keywords": [
    "website",
    "HTML",
    "CSS",
    "JavaScript",
    "Bootstrap",
    "Vite"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint:js": "eslint \"src/**/*.js\"",
    "lint:html": "eslint \"src/**/*.html\"",
    "lint:css": "stylelint \"src/**/*.css\" --allow-empty-input",
    "format:js": "eslint \"src/**/*.js\" --fix",
    "format:html": "eslint \"src/**/*.html\" --fix",
    "format:css": "stylelint \"src/**/*.css\" --fix --allow-empty-input",
    "format:prettier": "prettier --write \"src/**/*.{js,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,css}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@html-eslint/eslint-plugin": "^0.60.0",
    "@html-eslint/parser": "^0.60.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.10.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.0.10"
  }
}

